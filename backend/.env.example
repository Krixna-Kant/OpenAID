# =============================================================================
# OpenAid Provisioner — environment variables
# Copy to .env and fill in values. See README "Demo vs live" section.
# =============================================================================

# --- Google Gemini / Vertex AI (Phase 1) ---
# RECOMMENDED: GCP free trial — https://cloud.google.com/free
# Setup guide: docs/GCP_FREE_TRIAL_SETUP.md
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
USE_VERTEX_AI=true
GEMINI_MODEL=gemini-2.5-flash

# OPTIONAL fallback only (USE_VERTEX_AI=false):
# GOOGLE_API_KEY=

# --- Fivetran (Phase 2–3) — 14-day trial: https://fivetran.com ---
# Setup: docs/FIVETRAN_MCP_SETUP.md
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_GROUP_ID=
FIVETRAN_ALLOW_WRITES=false
FIVETRAN_USE_MCP=true
# MCP subprocess — requires uv: https://docs.astral.sh/uv/
FIVETRAN_MCP_COMMAND=uvx
FIVETRAN_MCP_ARGS=--from git+https://github.com/fivetran/fivetran-mcp fivetran-mcp
FIVETRAN_MCP_TIMEOUT=120

# --- BigQuery (Phase 4) — post-sync field briefings ---
BIGQUERY_PROJECT=
BIGQUERY_DATASET=

# --- App ---
CORS_ORIGINS=http://localhost:3000
# true = simulate Fivetran provision; false = use real APIs when creds + writes enabled
DEMO_MODE=true
